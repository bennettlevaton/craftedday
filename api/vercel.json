{
  "crons": [
    {
      "path": "/api/cron/generate-daily",
      "schedule": "0 8 * * *"
    },
    {
      "path": "/api/cron/generate-reel",
      "schedule": "0 17 * * *"
    }
  ],
  "functions": {
    "app/api/meditation/worker/route.ts": {
      "maxDuration": 800,
      "experimentalTriggers": [
        {
          "type": "queue/v2beta",
          "topic": "meditation-generate",
          "maxConcurrency": 1
        }
      ]
    },
    "app/api/cron/generate-reel/route.ts": {
      "maxDuration": 800,
      "includeFiles": "lib/fonts/**"
    }
  }
}
