#!/usr/bin/env bash
# Build + upload production iOS app to TestFlight.
#
# Requires:
#   - Distribution signing set up in Xcode (Runner target → Signing & Capabilities)
#   - An App Store Connect API key, OR an app-specific password for your Apple ID
#
# Upload auth — set ONE of:
#   APP_STORE_CONNECT_API_KEY_ID + APP_STORE_CONNECT_API_ISSUER_ID
#     (with the .p8 placed at ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8)
#   OR
#   APPLE_ID + APPLE_APP_SPECIFIC_PASSWORD

set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

export APPLE_ID="bennett@thebabybear.com"
export APPLE_APP_SPECIFIC_PASSWORD="tlun-ctgo-pqfu-ytwe"

PUBSPEC="$ROOT/mobile/pubspec.yaml"
CURRENT_VERSION_LINE="$(grep '^version:' "$PUBSPEC")"
MARKETING="$(echo "$CURRENT_VERSION_LINE" | sed -E 's/^version:[[:space:]]*([^+]+)\+.*/\1/')"
BUILD_NUM="$(echo "$CURRENT_VERSION_LINE" | sed -E 's/^version:[[:space:]]*[^+]+\+([0-9]+).*/\1/')"
NEXT_BUILD=$((BUILD_NUM + 1))
sed -i '' -E "s/^version:.*/version: ${MARKETING}+${NEXT_BUILD}/" "$PUBSPEC"

echo "→ Building production iOS IPA for TestFlight"
echo "  API:     https://craftedday.com"
echo "  Version: ${MARKETING}+${NEXT_BUILD} (was ${MARKETING}+${BUILD_NUM})"
echo ""

cd "$ROOT/mobile"

# Native-asset packages (objective_c, pulled in transitively) cache their
# built framework per-arch under build/. Without a clean, `flutter build ipa`
# after a simulator run can ship the simulator slice and get rejected by
# App Store Connect:
#   "objective_c executable references an unsupported platform in the arm64 slice"
flutter clean
flutter pub get

flutter build ipa \
  --dart-define=API_BASE_URL="https://craftedday.com" \
  --dart-define=CLERK_PUBLISHABLE_KEY="pk_live_Y2xlcmsuY3JhZnRlZGRheS5jb20k" \
  --dart-define=REVENUECAT_API_KEY="appl_JjKCtphOHklZhBzOHfkPrajvIYk" \
  --release

IPA_PATH="$(ls -t "$ROOT/mobile/build/ios/ipa/"*.ipa 2>/dev/null | head -n1)"

if [ -z "$IPA_PATH" ]; then
  echo "✗ No .ipa found in mobile/build/ios/ipa/"
  exit 1
fi

echo ""
echo "→ Built: $IPA_PATH"
echo ""

if [ -n "$APP_STORE_CONNECT_API_KEY_ID" ] && [ -n "$APP_STORE_CONNECT_API_ISSUER_ID" ]; then
  echo "→ Uploading via App Store Connect API key"
  xcrun altool --upload-app \
    --type ios \
    --file "$IPA_PATH" \
    --apiKey "$APP_STORE_CONNECT_API_KEY_ID" \
    --apiIssuer "$APP_STORE_CONNECT_API_ISSUER_ID"
elif [ -n "$APPLE_ID" ] && [ -n "$APPLE_APP_SPECIFIC_PASSWORD" ]; then
  echo "→ Uploading as $APPLE_ID"
  xcrun altool --upload-app \
    --type ios \
    --file "$IPA_PATH" \
    --username "$APPLE_ID" \
    --password "$APPLE_APP_SPECIFIC_PASSWORD"
else
  echo "⚠ No upload credentials set. Open Transporter.app and drag in:"
  echo "  $IPA_PATH"
  exit 0
fi

echo ""
echo "✓ Uploaded to TestFlight. Processing takes ~10–30 min."
