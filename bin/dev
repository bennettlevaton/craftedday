#!/usr/bin/env bash
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

# Check env exists
if [ ! -f "$ROOT/api/.env.local" ]; then
  echo "✗ api/.env.local not found — run bin/setup first"
  exit 1
fi

# Colors
BLUE='\033[0;34m'
RESET='\033[0m'

prefix_output() {
  local label="$1"
  local color="$2"
  while IFS= read -r line; do
    echo -e "${color}[${label}]${RESET} $line"
  done
}

cleanup() {
  echo ""
  echo "→ Shutting down API..."
  if [ -n "$API_PID" ]; then
    pkill -P "$API_PID" 2>/dev/null || true
    kill "$API_PID" 2>/dev/null || true
  fi
  echo "→ Done"
}

trap cleanup EXIT INT TERM

# Start API in background with prefixed output
echo "→ Starting API (Next.js)..."
(cd "$ROOT/api" && npm run dev 2>&1 | prefix_output "api" "$BLUE") &
API_PID=$!

# Boot an iOS simulator if none is running
if ! xcrun simctl list devices booted | grep -q Booted; then
  echo "→ Booting iOS simulator..."
  SIM_ID=$(xcrun simctl list devices available -j \
    | /usr/bin/python3 -c 'import json,sys
d=json.load(sys.stdin)["devices"]
runtimes=sorted([r for r in d if "iOS" in r], reverse=True)
for r in runtimes:
    for dev in d[r]:
        if "iPhone" in dev["name"]:
            print(dev["udid"]); sys.exit(0)')
  xcrun simctl boot "$SIM_ID"
  open -a Simulator
fi

echo ""
echo "  api → http://localhost:3000"
echo "  Flutter runs in foreground — r=hot reload, R=restart, q=quit"
echo ""

# Flutter in foreground — keeps stdin for hot reload keys
cd "$ROOT/mobile"
flutter run
