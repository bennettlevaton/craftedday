#!/usr/bin/env bash
set -e

ROOT="$(cd "$(dirname "$0")/.." && pwd)"

if [ ! -f "$ROOT/api/.env.local" ]; then
  echo "✗ api/.env.local not found — run bin/setup first"
  exit 1
fi

BLUE='\033[0;34m'
GREEN='\033[0;32m'
RESET='\033[0m'

prefix_output() {
  local label="$1"
  local color="$2"
  while IFS= read -r line; do
    echo -e "${color}[${label}]${RESET} $line"
  done
}

# Boot iOS simulator if none running
if ! xcrun simctl list devices booted | grep -q Booted; then
  echo "→ Booting iOS simulator..."
  SIM_ID=$(xcrun simctl list devices available -j \
    | /usr/bin/python3 -c 'import json,sys
d=json.load(sys.stdin)["devices"]
runtimes=sorted([r for r in d if "iOS" in r], reverse=True)
for r in runtimes:
    for dev in d[r]:
        if "iPhone" in dev["name"]:
            print(dev["udid"]); sys.exit(0)')
  xcrun simctl boot "$SIM_ID"
  open -a Simulator
fi

cleanup() {
  echo ""
  echo "→ Shutting down..."
  for pid in "$API_PID" "$FLUTTER_PID"; do
    if [ -n "$pid" ]; then
      pkill -P "$pid" 2>/dev/null || true
      kill "$pid" 2>/dev/null || true
    fi
  done
  wait 2>/dev/null || true
  echo "→ Done"
}

trap cleanup EXIT INT TERM

echo "→ Starting API..."
(cd "$ROOT/api" && npm run dev 2>&1 | prefix_output "api    " "$BLUE") &
API_PID=$!

echo "→ Starting Flutter..."
# `script -q /dev/null` gives Flutter a pseudo-TTY so it emits clean log lines
(cd "$ROOT/mobile" && script -q /dev/null flutter run -d iPhone 2>&1 | prefix_output "flutter" "$GREEN") &
FLUTTER_PID=$!

echo ""
echo "  api → http://localhost:3000"
echo "  Ctrl+C to stop both"
echo "  (hot reload: save a .dart file — automatic)"
echo ""

wait
